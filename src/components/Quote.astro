---
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

import ereaderImage from "../assets/image.png";
import CheckIcon from "./icons/CheckIcon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="ereader" id="ereader">
  <div class="ereader-image reveal-right">
    <Image src={ereaderImage} alt="E-Reader" />
  </div>

  <div class="ereader-info">
    <div>
      <p class="subtitle reveal-left">{t("quote.subtitle")}</p>
      <h2 class="reveal" set:html={t("quote.title")} />
    </div>

    <p>
      {t("quote.desc")}
    </p>

    <ul class="ereader-info-list">
      <li class="reveal-left"><CheckIcon /> {t("quote.feature.inventory")}</li>
      <li class="reveal-left"><CheckIcon /> {t("quote.feature.margin")}</li>
      <li class="reveal-left"><CheckIcon /> {t("quote.feature.quotes")}</li>
    </ul>
  </div>
</div>

<style>
  .ereader {
    background-color: var(--card-color);

    display: flex;
    gap: 32px;

    padding: 96px 48px;
  }

  .ereader-info {
    display: flex;
    flex-direction: column;
    gap: 32px;

    width: 50%;
  }

  .ereader-info-list {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 16px;
  }

  .ereader-info-list li {
    display: flex;
    align-items: center;
    gap: 16px;

    color: #fff;
  }

  .ereader-image {
    width: 50%;
  }

  .ereader-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom;
    display: block;
  }

  .ereader-info-list li:nth-child(1) {
    transition-delay: 0.1s;
  }
  .ereader-info-list li:nth-child(2) {
    transition-delay: 0.2s;
  }
  .ereader-info-list li:nth-child(3) {
    transition-delay: 0.3s;
  }

  @media (max-width: 48rem) {
    .ereader {
      flex-direction: column;
    }

    .ereader-info {
      width: 100%;
      padding: 32px;
    }

    .ereader-info h2,
    .ereader-info p {
      max-width: 100%;
    }

    .ereader-image {
      width: 100%;
      min-height: 350px;
    }
  }
</style>
