---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

import FeatureCard from "./FeatureCard.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Feature {
  iconName: "printer" | "laser" | "history";
  title: string;
  description: string;
}

const features: Feature[] = [
  {
    iconName: "printer",
    title: "featureCard.printing.title",
    description: "featureCard.printing.desc",
  },
  {
    iconName: "laser",
    title: "featureCard.laser.title",
    description: "featureCard.laser.desc",
  },
  {
    iconName: "history",
    title: "featureCard.history.title",
    description: "featureCard.history.desc",
  },
];
---

<div class="features" id="features">
  <p class="subtitle reveal-left">{t("features.subtitle")}</p>
  <h2 class="reveal" set:html={t("features.title")} />

  <div class="features-cards">
    {
      features.map((card) => (
        <FeatureCard
          title={t(card.title as any)}
          description={t(card.description as any)}
          icon={card.iconName as any}
        />
      ))
    }
  </div>
</div>

<style>
  .features {
    padding: 96px 48px;
  }

  .features-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;

    margin-top: 64px;
  }

  .features-cards :global(.feature-card:nth-child(1)) {
    transition-delay: 0.1s;
  }
  .features-cards :global(.feature-card:nth-child(2)) {
    transition-delay: 0.2s;
  }
  .features-cards :global(.feature-card:nth-child(3)) {
    transition-delay: 0.3s;
  }
  .features-cards :global(.feature-card:nth-child(4)) {
    transition-delay: 0.4s;
  }
</style>
